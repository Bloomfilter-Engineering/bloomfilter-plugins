{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py SessionStart",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py UserPromptSubmit",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py PostToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py PreCompact",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py SubagentStart",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py SubagentStop",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python || command -v python3) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py Stop",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
