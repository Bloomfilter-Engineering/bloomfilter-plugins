{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py SessionStart",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py UserPromptSubmit",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py PermissionRequest",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py PostToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) ${CLAUDE_PLUGIN_ROOT}/scripts/collect_hook.py Stop",
            "timeout": 30
          }
        ]
      }
    ]
  }
}