{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" SessionStart; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" SessionStart",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" UserPromptSubmit; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" UserPromptSubmit",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" PreToolUse; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" PermissionRequest; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" PermissionRequest",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" PostToolUse; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" PostToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" SubagentStart; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" SubagentStart",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" SubagentStop; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" SubagentStop",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Variable `# <#` > /dev/null 2>&1; sh \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh\" Stop; exit #> ; & \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-hook.ps1\" Stop",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
